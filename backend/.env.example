# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/healthcare

# Chat
CHAT_MODEL=gpt-4.1-nano
ANALYSIS_MODEL=gpt-4.1
CHAT_MAX_TURNS=8
CHAT_SESSION_TTL_MINUTES=30
CHAT_RATE_LIMIT_PER_MINUTE=5
CHAT_RATE_LIMIT_PER_HOUR=20
CHAT_MAX_ACTIVE_SESSIONS=100
DAILY_LLM_CALL_LIMIT=500
CHAT_MESSAGE_MAX_LENGTH=500

# App
CORS_ORIGINS=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-secure-password
